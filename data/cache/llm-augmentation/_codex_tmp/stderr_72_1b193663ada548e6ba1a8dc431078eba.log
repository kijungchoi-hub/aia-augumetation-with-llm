    }
  ],
  "utterance_labels": [
    {
      "utterance_id": 1,
      "speaker": "상담사|고객|미상",
      "label": "고객요청|상담사확인|서류안내|처리안내|결과통보|불만제기|감정표현|일반발화",
      "text": "string"
    }
  ],
  "variants": [
    {
