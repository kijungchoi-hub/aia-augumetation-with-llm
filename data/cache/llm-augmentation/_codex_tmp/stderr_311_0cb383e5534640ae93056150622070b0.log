      "result": "string"
    }
  },
  "keyword_slots": {
    "intent_type": "string",
    "request_type": "string",
    "contract_count": "string",
    "payment_amounts": ["string"],
    "date_values": ["string"],
    "institutions": ["string"],
    "channels": ["string"],
    "documents": ["string"],
    "actions": ["string"],
    "outcomes": ["string"],
    "product_names": ["string"],
    "keywords": ["string"]
  },
  "keyword_labels": [
    {
